<!DOCTYPE html>
<html lang="ro">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - LibrarieOnline</title>

    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body>
    <header>
        <nav class="navbar navbar-light bg-light border-bottom mb-3">
            <div class="container-fluid">

                <a class="navbar-brand" asp-controller="Home" asp-action="Index">
                    LibrarieOnline
                </a>

                <ul class="navbar-nav flex-row gap-3 align-items-center">
                    <li class="nav-item">
                        <a class="nav-link text-dark" asp-controller="Home" asp-action="Index">Home</a>
                    </li>

                    <li class="nav-item">
                        <a class="nav-link text-dark" asp-controller="Books" asp-action="Index">📚 Catalog</a>
                    </li>

                    <li class="nav-item">
                        <a class="nav-link text-dark" asp-controller="Authors" asp-action="Index">👤 Autori</a>
                    </li>

                    <li class="nav-item">
                        <a class="nav-link text-dark" asp-controller="Categories" asp-action="Index">📂 Categorii</a>
                    </li>

                    <li class="nav-item">
                        <a class="nav-link text-dark" asp-controller="Publishers" asp-action="Index">🏢 Edituri</a>
                    </li>

                    <li class="nav-item">
                        <a class="nav-link text-dark" asp-controller="Orders" asp-action="Index">🛒 Coș</a>
                    </li>

                    <li class="nav-item">
                        <a class="nav-link text-dark" asp-area="Identity" asp-page="/Account/Register">Register</a>
                    </li>

                    <li class="nav-item">
                        <a class="nav-link text-dark" asp-area="Identity" asp-page="/Account/Login">Login</a>
                    </li>
                </ul>

            </div>
        </nav>
    </header>

    <!-- CONTINUT PAGINA -->
    <div class="container">
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>

    <!-- FOOTER -->
    <footer class="border-top footer text-muted">
        <div class="container">
            © 2026 - LibrarieOnline - Privacy
        </div>
    </footer>

    <!-- SCRIPTS -->
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>